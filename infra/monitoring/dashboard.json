{
  "$schema": "https://grafana.com/schema/dashboard/v0",
  "title": "Arco Control Plane Operator",
  "description": "Operational dashboard for orchestration runtime signals plus ADR-034 PI-1 repair, reconcile, stale-fence, and compatibility telemetry",
  "uid": "arco-orchestration-operator",
  "tags": ["arco", "orchestration", "operator"],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Backlog Depth by Lane",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(arco_orch_backlog_depth) by (lane)",
          "legendFormat": "{{lane}}"
        }
      ],
      "description": "Current actionable backlog depth across orchestration lanes"
    },
    {
      "title": "Compaction Lag (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "max(arco_orch_compaction_lag_seconds)",
          "legendFormat": "max"
        }
      ],
      "description": "Compaction watermark lag used by guardrail controllers"
    },
    {
      "title": "Run Key Conflicts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "max(arco_orch_run_key_conflicts)",
          "legendFormat": "conflicts"
        }
      ],
      "description": "Durable run-key conflict row count"
    },
    {
      "title": "Controller Reconcile p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(arco_orch_controller_reconcile_seconds_bucket[5m])) by (le, controller))",
          "legendFormat": "p95 {{controller}}"
        }
      ],
      "description": "Reconcile latency p95 by controller"
    },
    {
      "title": "SLO Target (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "max(arco_orch_slo_target_seconds) by (slo)",
          "legendFormat": "target {{slo}}"
        }
      ],
      "description": "Configured runtime SLO targets"
    },
    {
      "title": "SLO Observed (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "max(arco_orch_slo_observed_seconds) by (slo)",
          "legendFormat": "observed {{slo}}"
        }
      ],
      "description": "Observed runtime SLO signals"
    },
    {
      "title": "SLO Breaches (5m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(increase(arco_orch_slo_breaches_total[5m])) by (slo)",
          "legendFormat": "{{slo}}"
        }
      ],
      "description": "Recent SLO breach increments by SLO key"
    },
    {
      "title": "Control-Plane Repair Pending (15m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(increase(arco_catalog_repair_pending_total[15m])) by (domain)",
          "legendFormat": "catalog {{domain}}"
        },
        {
          "expr": "sum(increase(arco_flow_orch_repair_pending_total[15m]))",
          "legendFormat": "orchestration"
        }
      ],
      "description": "Visible pointer-CAS commits that still need repair of legacy mirrors or commit records"
    },
    {
      "title": "Control-Plane Reconcile Issues (15m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(increase(arco_catalog_reconciler_issues_total{repairable=\"true\"}[15m])) by (domain)",
          "legendFormat": "catalog {{domain}}"
        },
        {
          "expr": "sum(increase(arco_flow_orch_reconciler_repair_issues_total[15m])) by (reason)",
          "legendFormat": "orch {{reason}}"
        }
      ],
      "description": "Repairable current-head issues detected by catalog and orchestration reconciler dry runs"
    },
    {
      "title": "Control-Plane Repairs (15m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "sum(increase(arco_catalog_reconciler_repairs_total[15m])) by (status)",
          "legendFormat": "catalog {{status}}"
        },
        {
          "expr": "sum(increase(arco_flow_orch_reconciler_repairs_total[15m])) by (status)",
          "legendFormat": "orch {{status}}"
        }
      ],
      "description": "Repair attempts and outcomes for current-head reconciliation"
    },
    {
      "title": "Stale Fence Rejects (15m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "sum(increase(arco_flow_orch_compactor_stale_fencing_rejects_total[15m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ],
      "description": "Lock-backed stale-fence rejections during orchestration compaction"
    },
    {
      "title": "Legacy Epoch Payloads (15m increase)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "targets": [
        {
          "expr": "sum(increase(arco_flow_orch_compactor_legacy_epoch_requests_total[15m])) by (endpoint, status, request_mode)",
          "legendFormat": "{{endpoint}} {{status}} {{request_mode}}"
        }
      ],
      "description": "Compatibility telemetry for legacy orchestration compactor payloads during PI-1 rollout"
    }
  ]
}
